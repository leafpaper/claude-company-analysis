# Claude Code 投资分析 Skill — 环境变量模板
#
# ⚠️  不要把真实 token 提交到 git。
# 推荐做法：把下面的 export 语句写到你的 shell 配置文件（~/.zshrc 或 ~/.bashrc），
#         不要在仓库里放 .env。
# 若你坚持用 .env：复制本文件为 .env 并填入真实值，然后确保 .env 已在 .gitignore。

# ------------------------------------------------------------
# Tushare Pro Token（必需，A 股 / 港股分析用）
# ------------------------------------------------------------
# 注册地址: https://tushare.pro/register
# 建议申请学生权限获 5000+ 免费积分；或购买 2000 积分（约 ¥200）
# 积分决定可调接口范围：5000 积分可调所有核心财报接口
export TUSHARE_TOKEN="YOUR_TUSHARE_TOKEN_HERE"

# ------------------------------------------------------------
# 可选：缓存目录（默认 ~/.claude/plugins/company-analysis/.cache）
# ------------------------------------------------------------
# export COMPANY_ANALYSIS_CACHE="$HOME/.claude/plugins/company-analysis/.cache"

# ------------------------------------------------------------
# 可选：缓存 TTL（默认 7 天）
# ------------------------------------------------------------
# export COMPANY_ANALYSIS_CACHE_TTL=7

# ------------------------------------------------------------
# 美股不需要 token（yfinance 免费）
# 港股需要 TUSHARE_TOKEN（yfinance 做 fallback）
# ------------------------------------------------------------
